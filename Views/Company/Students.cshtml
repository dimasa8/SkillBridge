@model List<ApplicationUser>
@{
    ViewData["Title"] = "الطلاب";
    var specs = ViewBag.Specializations as List<Specialization> ?? new List<Specialization>();
    int? selected = ViewBag.SelectedSpecialization;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <span class="section-eyebrow">اكتشف المواهب</span>
            <h2 class="mb-0">الطلاب</h2>
        </div>
        <form method="get" class="d-flex gap-2">
            <select name="specializationId" class="form-select" onchange="this.form.submit()">
                <option value="">كل التخصصات</option>
                @foreach (var s in specs)
                {
                    <option value="@s.Id" selected="@(selected == s.Id)">@s.Name</option>
                }
            </select>
        </form>
    </div>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var student in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100"><div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="spec-icon" style="width:52px;height:52px;font-size:1.4rem;margin:0"><i class="bi bi-person-fill"></i></div>
                            <div>
                                <h5 class="mb-0">@student.FullName</h5>
                                <small class="text-muted">@(student.Specialization?.Name ?? "بدون تخصص")</small>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="score-badge" style="font-size:.85rem"><i class="bi bi-star-fill"></i> @student.Score نقطة</span>
                            <a asp-action="StudentProfile" asp-route-id="@student.Id" class="btn btn-outline-primary btn-sm">التفاصيل</a>
                        </div>
                    </div></div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">لا يوجد طلاب مطابقون.</div>
    }
</div>
