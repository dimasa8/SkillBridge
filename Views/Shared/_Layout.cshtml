@using Microsoft.AspNetCore.Identity
@using SkillBridge.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ApplicationUser? currentUser = null;
    var roleName = "";
    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            var roles = await UserManager.GetRolesAsync(currentUser);
            roleName = roles.FirstOrDefault() ?? "";
        }
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkillBridge</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sb-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">SB</span>
                SkillBridge
            </a>
            <button class="navbar-toggler text-white border-light" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <i class="bi bi-list fs-3"></i>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    @if (roleName == "Student")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Index"><i class="bi bi-grid me-1"></i> لوحتي</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Profile"><i class="bi bi-person me-1"></i> ملفي وتقدّمي</a></li>
                    }
                    else if (roleName == "Company")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Index"><i class="bi bi-grid me-1"></i> اللوحة</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Students"><i class="bi bi-people me-1"></i> الطلاب</a></li>
                    }
                    else if (roleName == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i> لوحة التحكم</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Specializations"><i class="bi bi-collection me-1"></i> التخصصات</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Students"><i class="bi bi-mortarboard me-1"></i> الطلاب</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Companies"><i class="bi bi-building me-1"></i> الشركات</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (currentUser != null)
                    {
                        @if (roleName == "Student")
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                <span class="score-badge"><i class="bi bi-star-fill"></i> @currentUser.Score نقطة</span>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5 me-1"></i>
                                @(roleName == "Company" ? currentUser.CompanyName : currentUser.FullName)
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text small text-muted">@currentUser.Email</span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                        <button type="submit" class="btn btn-danger btn-sm w-100"><i class="bi bi-box-arrow-right me-1"></i> تسجيل الخروج</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">تسجيل الدخول</a></li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">إنشاء حساب</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Message"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-1"></i> @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="sb-footer">
        <div class="container">
            <p class="mb-1"><strong>SkillBridge</strong> — منصة ربط الطلاب بسوق العمل</p>
            <p class="mb-0 small">© @DateTime.Now.Year جميع الحقوق محفوظة</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
