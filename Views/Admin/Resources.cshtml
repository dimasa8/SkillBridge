@model Stage
@{ ViewData["Title"] = "مصادر: " + Model.Title; }

<div class="container py-4">
    <a asp-action="Stages" asp-route-specializationId="@Model.SpecializationId" class="btn btn-light-blue btn-sm mb-3"><i class="bi bi-arrow-right me-1"></i> رجوع للمراحل</a>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <span class="section-eyebrow">@Model.Specialization?.Name</span>
            <h2 class="mb-0">مصادر: @Model.Title</h2>
        </div>
        <a asp-action="CreateResource" asp-route-stageId="@Model.Id" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> إضافة مصدر</a>
    </div>

    @if (Model.Resources.Any())
    {
        @foreach (var res in Model.Resources)
        {
            var (icon, cls) = res.Type switch
            {
                "video" => ("bi-play-circle-fill", "type-video"),
                "article" => ("bi-file-text-fill", "type-article"),
                _ => ("bi-link-45deg", "type-link")
            };
            <div class="resource-item">
                <div class="resource-type-icon @cls"><i class="bi @icon"></i></div>
                <div class="flex-grow-1">
                    <h6 class="mb-0">@res.Title</h6>
                    <small class="text-muted">@res.Description</small><br>
                    <a href="@res.Url" target="_blank" class="small" dir="ltr">@res.Url</a>
                </div>
                <form asp-action="DeleteResource" method="post" onsubmit="return confirm('حذف المصدر؟')">
                    <input type="hidden" name="id" value="@res.Id" />
                    <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                </form>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">لا توجد مصادر لهذه المرحلة. أضف رابط أو فيديو.</div>
    }
</div>
