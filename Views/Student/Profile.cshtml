@model List<StudentProgress>
@{
    ViewData["Title"] = "ملفي";
    var spec = ViewBag.Specialization as Specialization;
    int score = ViewBag.Score ?? 0;
}

<div class="container py-4">
    <div class="row g-4">
        <!-- بطاقة الملف -->
        <div class="col-lg-4">
            <div class="card text-center"><div class="card-body p-4">
                <div class="spec-icon mx-auto" style="width:80px;height:80px;font-size:2.2rem"><i class="bi bi-person-fill"></i></div>
                <h4 class="mt-3 mb-1">@ViewBag.FullName</h4>
                <p class="text-muted small mb-3" dir="ltr">@ViewBag.Email</p>
                <span class="role-pill role-student mb-3 d-inline-block">طالب</span>
                <hr>
                <div class="d-flex justify-content-around">
                    <div>
                        <div class="fs-3 fw-bold text-primary">@score</div>
                        <small class="text-muted">نقطة</small>
                    </div>
                    <div>
                        <div class="fs-3 fw-bold text-primary">@Model.Count</div>
                        <small class="text-muted">مرحلة مكتملة</small>
                    </div>
                </div>
                @if (spec != null)
                {
                    <hr>
                    <p class="mb-0"><i class="bi @(string.IsNullOrEmpty(spec.Icon) ? "bi-book" : spec.Icon) text-primary me-1"></i> @spec.Name</p>
                }
            </div></div>
        </div>

        <!-- سجل الإنجاز -->
        <div class="col-lg-8">
            <div class="card"><div class="card-body">
                <h4 class="mb-3"><i class="bi bi-clock-history me-1 text-primary"></i> سجل الإنجاز</h4>
                @if (Model.Any())
                {
                    <table class="table table-clean mb-0">
                        <thead>
                            <tr><th>المرحلة</th><th>النقاط</th><th>التاريخ</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td><i class="bi bi-check-circle-fill text-success me-1"></i> @p.Stage?.Title</td>
                                    <td><span class="score-badge" style="font-size:.8rem;padding:.2rem .7rem"><i class="bi bi-star-fill"></i> @p.PointsEarned</span></td>
                                    <td class="text-muted small">@p.CompletedAt.ToString("yyyy/MM/dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info mb-0">لسا ما خلّصت أي مرحلة. ابدأ الآن من لوحتك!</div>
                }
            </div></div>
        </div>
    </div>
</div>
