@model List<Specialization>
@{ ViewData["Title"] = "اختر تخصصك"; }

<div class="container py-5">
    <div class="text-center mb-5">
        <span class="section-eyebrow">الخطوة الأولى</span>
        <h2 class="section-title">اختر التخصص اللي بدك تتعلّمه</h2>
        <p class="text-muted">تقدر تبدأ رحلتك بمسار واحد وتركّز عليه.</p>
    </div>

    <div class="row g-4">
        @foreach (var spec in Model)
        {
            <div class="col-md-4">
                <div class="spec-card card h-100"><div class="card-body d-flex flex-column">
                    <div class="spec-icon"><i class="bi @(string.IsNullOrEmpty(spec.Icon) ? "bi-book" : spec.Icon)"></i></div>
                    <h4>@spec.Name</h4>
                    <p class="text-muted flex-grow-1">@spec.Description</p>
                    <span class="role-pill role-student mb-3">@spec.Stages.Count مراحل</span>
                    <form asp-action="ChooseSpecialization" method="post">
                        <input type="hidden" name="id" value="@spec.Id" />
                        <button type="submit" class="btn btn-primary w-100">اختر هذا التخصص</button>
                    </form>
                </div></div>
            </div>
        }
    </div>
</div>
