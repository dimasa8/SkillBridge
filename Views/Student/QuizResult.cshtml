@{
    ViewData["Title"] = "نتيجة الاختبار";
    int earned = ViewBag.Earned ?? 0;
    int total = ViewBag.Total ?? 0;
    int correct = ViewBag.CorrectCount ?? 0;
    int qCount = ViewBag.QuestionCount ?? 0;
    int stageId = ViewBag.StageId ?? 0;
    bool already = ViewBag.AlreadyCompleted ?? false;
    int pct = total > 0 ? (int)((double)earned / total * 100) : 0;
    bool passed = pct >= 50;
}

<div class="container py-5" style="max-width:620px">
    <div class="card text-center">
        <div class="card-body p-5">
            <div class="spec-icon mx-auto" style="width:90px;height:90px;font-size:2.6rem;background:@(passed ? "var(--success-bg)" : "var(--danger-bg)");color:@(passed ? "var(--success)" : "var(--danger)")">
                <i class="bi @(passed ? "bi-trophy-fill" : "bi-emoji-neutral")"></i>
            </div>
            <h2 class="mt-3">@(passed ? "أحسنت! 🎉" : "محاولة جيدة")</h2>

            <div class="display-3 fw-bold text-primary my-3">@pct%</div>

            <p class="lead text-muted">
                أجبت صح على <strong>@correct</strong> من <strong>@qCount</strong> أسئلة
            </p>

            @if (already)
            {
                <div class="alert alert-info">أنجزت هذه المرحلة من قبل — لن تُضاف النقاط مرة ثانية.</div>
            }
            else
            {
                <div class="score-badge fs-5 my-2"><i class="bi bi-star-fill"></i> +@earned نقطة أُضيفت لرصيدك</div>
            }

            <div class="d-flex gap-2 justify-content-center mt-4 flex-wrap">
                <a asp-action="Stage" asp-route-id="@stageId" class="btn btn-outline-primary">مراجعة المرحلة</a>
                <a asp-action="Index" class="btn btn-primary">متابعة المسار <i class="bi bi-arrow-left ms-1"></i></a>
            </div>
        </div>
    </div>
</div>
