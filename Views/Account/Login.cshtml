@model LoginViewModel
@{ ViewData["Title"] = "تسجيل الدخول"; }

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-head">
            <h2>مرحباً بعودتك</h2>
            <p>سجّل دخولك للمتابعة</p>
        </div>
        <div class="auth-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="example@email.com" dir="ltr" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" dir="ltr" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">دخول</button>
                <p class="text-center mb-0 small">
                    ما عندك حساب؟ <a asp-action="Register">أنشئ حساب</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
